# ====================================================
# V12 God-Engine — Environment Variables
# Copy this file to .env and fill in your keys
# ====================================================

# REQUIRED: Google Gemini API Key (core AI engine)
# Get yours at: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# OPTIONAL: BallDontLie API Key (NBA/NFL/MLB stats + odds)
# Free tier available at: https://www.balldontlie.io
# Required for: Live Games page, Player Props odds, team stats
BALLDONTLIE_API_KEY=YOUR_BALLDONTLIE_KEY_HERE

# OPTIONAL: Server port (default: 3001)
PORT=3001

# OPTIONAL: Node environment
NODE_ENV=development

# OPTIONAL: Redis URL for caching (falls back to in-memory if not set)
# REDIS_URL=redis://localhost:6379
